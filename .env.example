# Server-default OpenAI API key. Optional — users can also supply their own
# key per session via the ⚙ Settings panel in the UI.
OPENAI_API_KEY=sk-...

# Default model used for resolution, classification, extraction, and merging.
# Users can override per session in the Settings panel. Allowed values:
#   gpt-5  (recommended)
#   gpt-5-mini
#   gpt-5-nano
#   gpt-4.1
#   gpt-4.1-mini
#   gpt-4o
#   gpt-4o-mini
OPENAI_MODEL=gpt-5

# Optional override for the vision-capable model used during statement
# extraction. Defaults to OPENAI_MODEL.
# OPENAI_VISION_MODEL=gpt-5
